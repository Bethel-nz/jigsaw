  <!DOCTYPE html>
  <html lang="en">
    @meta {{
      title: "JigSaw title goes here",
      link: (rel: "stylesheet", href: "/static/styles.css")
    }}

  <body>
    <div id="jigsaw-root">
      <div class="app-container">
        <!-- Persistent Navigation Island -->
        {% island "nav" %}
          <nav class="navbar">
            <div class="logo">
              <a href="/demo" style="font-weight: 700; font-size: 1.5rem;">Jigsaw</a>
            </div>
            <div class="nav-links">
              <a href="/demo" class="nav-link" data-transition="slide-right">Home</a>
              <a href="/blog" class="nav-link" data-transition="slide-left">Blog</a>
            </div>
            
            <!-- Audio Player Island demonstrating @sync -->
            {% island "player" %}
            <div class="player">
               <div class="player-controls">
                  <span @sync="now-playing">Now Playing: Persistence FM</span>
                  <button @click="
                    $ref.audio.paused ? ($ref.audio.play(), $el.text('Pause')) : ($ref.audio.pause(), $el.text('Play'))
                  ">Play</button>
               </div>
               <audio data-ref="audio" src="/static/audio.mp3" style="display: none;"></audio>
            </div>
            {% endisland %}
          </nav>
        {% island "/" %}

        <!-- Dynamic Content -->
        <main>
          {% transition "fade" %}
            {{ content | safe }}
          {% endtransition %}
        </main>
      </div>
    </div>



    <script src="/static/jigsaw-router.js?v=3" defer></script>
  </body>
  </html>
